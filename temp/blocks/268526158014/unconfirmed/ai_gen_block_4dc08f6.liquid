        <path fill="#012169" d="M95.65 3.2l-3.407 21.62c-.062.37.229.705.61.705h3.458c.522 0 .968-.378 1.05-.89L100.72 3.01c.062-.37-.229-.705-.61-.705h-3.83c-.323 0-.581.227-.63.534z"/>
      </svg>
    {% endif %}
    {% if block.settings.button_text != blank %}
      <span class="ai-paypal-text-{{ ai_gen_id }}">{{ block.settings.button_text }}</span>
    {% endif %}
  </a>
</div>

{% schema %}
{
  "name": "PayPal button",
  "settings": [
    {
      "type": "header",
      "content": "Button settings"
    },
    {
      "type": "url",
      "id": "paypal_url",
      "label": "PayPal URL"
    },
    {
      "type": "paragraph",
      "content": "Enter your PayPal.me link (e.g., https://paypal.me/yourname) or PayPal checkout URL"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Checkout with"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show PayPal logo",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#FFC439"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover color",
      "default": "#F7B731"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Spacing above button",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "PayPal button"
    }
  ]
}
{% endschema %}
