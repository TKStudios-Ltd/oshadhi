{% doc %}
  @prompt
    Add a PayPal payment button to the cart page. The button should appear below or alongside the existing checkout button. It should link to a PayPal checkout URL or PayPal.me link (with a placeholder URL that can be easily updated). Style it to match PayPal's branding (yellow button with PayPal logo) and ensure it's responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-paypal-button-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin-top: {{ block.settings.spacing_top }}px;
  }

  .ai-paypal-button-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    border: none;
    border-radius: {{ block.settings.border_radius }}px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    gap: 10px;
    font-size: 16px;
    font-weight: 500;
  }

  .ai-paypal-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-1px);
  }

  .ai-paypal-button-{{ ai_gen_id }}:active {
    transform: translateY(0);
  }

  .ai-paypal-logo-{{ ai_gen_id }} {
    height: 24px;
    width: auto;
    display: block;
  }

  .ai-paypal-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-weight: 600;
    font-size: 16px;
    line-height: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-paypal-button-{{ ai_gen_id }} {
      padding: 12px 20px;
      font-size: 15px;
    }

    .ai-paypal-logo-{{ ai_gen_id }} {
      height: 20px;
    }

    .ai-paypal-text-{{ ai_gen_id }} {
      font-size: 15px;
    }
  }
{% endstyle %}

<div class="ai-paypal-button-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <a
    href="{{ block.settings.paypal_url }}"
    class="ai-paypal-button-{{ ai_gen_id }}"
    {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
  >
    {% if block.settings.show_logo %}
      <svg class="ai-paypal-logo-{{ ai_gen_id }}" viewBox="0 0 100 32" xmlns="http://www.w3.org/2000/svg">
