{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #CollectionListSwiper-{{ section.id }} {
    position: relative;
    overflow: hidden;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__title {
    margin: 0;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__arrow {
    width: 4.4rem;
    height: 4.4rem;
    min-width: 4.4rem;
    border-radius: 50%;
    border: 0.1rem solid rgba(var(--color-foreground), 0.12);
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__arrow:hover {
    transform: translateY(-0.1rem);
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__arrow.swiper-button-disabled {
    opacity: 0.35;
    cursor: default;
    transform: none;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__arrow svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper {
    overflow: visible;
  }

  #CollectionListSwiper-{{ section.id }} .swiper-wrapper {
    align-items: stretch;
  }

  #CollectionListSwiper-{{ section.id }} .swiper-slide {
    height: auto;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__track-wrap {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding-left: max(1.5rem, calc((100vw - var(--page-width)) / 2 + 1.5rem));
    padding-right: 1.5rem;
    box-sizing: border-box;
  }

  @media screen and (min-width: 750px) {
    #CollectionListSwiper-{{ section.id }} .collection-list-swiper__track-wrap {
      padding-left: max(5rem, calc((100vw - var(--page-width)) / 2 + 5rem));
      padding-right: 5rem;
    }
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__card {
    position: relative;
    display: block;
    text-decoration: none;
    border: 0.1rem solid var(--card-border-color, currentColor);
    border-radius: 1.2rem;
    aspect-ratio: 1 / 1;
    background: transparent;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    color: var(--card-text-color, rgb(var(--color-foreground)));
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__card:hover {
    transform: translateY(-0.2rem);
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__card-title {
    position: absolute;
    top: 2rem;
    left: 2rem;
    right: 2rem;
    z-index: 3;
    margin: 0;
    color: inherit;
    text-align: center;
    font-size: clamp(2rem, 2vw, 2.2rem);
    line-height: 1.15;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__image {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__image--primary {
    z-index: 1;
    opacity: 1;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__image--hover {
    z-index: 2;
    opacity: 0;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__card:hover .collection-list-swiper__image--primary {
    opacity: 0;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__card:hover .collection-list-swiper__image--hover {
    opacity: 1;
  }

  #CollectionListSwiper-{{ section.id }} .collection-list-swiper__placeholder {
    position: absolute;
    inset: 0;
    background: rgba(var(--color-foreground), 0.04);
  }

  @media screen and (max-width: 989px) {
    #CollectionListSwiper-{{ section.id }} .collection-list-swiper__header {
      margin-bottom: 2.4rem;
    }

    #CollectionListSwiper-{{ section.id }} .collection-list-swiper__card-title {
      top: 1.6rem;
      left: 1.6rem;
      right: 1.6rem;
      font-size: 1.9rem;
    }
  }

  @media screen and (max-width: 749px) {
    #CollectionListSwiper-{{ section.id }} .collection-list-swiper__header {
      align-items: flex-start;
    }

    #CollectionListSwiper-{{ section.id }} .collection-list-swiper__nav {
      gap: 0.8rem;
    }

    #CollectionListSwiper-{{ section.id }} .collection-list-swiper__arrow {
      width: 4rem;
      height: 4rem;
      min-width: 4rem;
    }

    #CollectionListSwiper-{{ section.id }} .collection-list-swiper__card-title {
      top: 1.4rem;
      left: 1.4rem;
      right: 1.4rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div id="CollectionListSwiper-{{ section.id }}" class="section-{{ section.id }}-padding">
    <div class="page-width isolate">
      {%- unless section.settings.title == blank -%}
        <div class="collection-list-swiper__header">
          <h2
            id="SectionHeading-{{ section.id }}"
            class="collection-list-swiper__title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          >
            {{ section.settings.title }}
          </h2>

          <div class="collection-list-swiper__nav no-js-hidden">
            <button
              type="button"
              class="collection-list-swiper__arrow collection-list-swiper__arrow--prev collection-list-swiper__arrow--prev-{{ section.id }}"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
            >
              <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                <path d="M9.5 3.5L5 8l4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <button
              type="button"
              class="collection-list-swiper__arrow collection-list-swiper__arrow--next collection-list-swiper__arrow--next-{{ section.id }}"
              aria-label="{{ 'general.slider.next_slide' | t }}"
            >
              <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                <path d="M6.5 3.5L11 8l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      {%- endunless -%}
    </div>

    <div class="collection-list-swiper__track-wrap">
      <div
        class="swiper collection-list-swiper js-collection-list-swiper"
        data-section-id="{{ section.id }}"
      >
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            {%- liquid
              assign card_collection = block.settings.collection
              assign primary_image = block.settings.custom_image
              if primary_image == blank and card_collection != blank
                assign primary_image = card_collection.featured_image
              endif

              assign hover_image = block.settings.hover_image
              assign collection_title = card_collection.title
              if block.settings.collection_name_override != blank
                assign collection_title = block.settings.collection_name_override
              endif
            -%}

            <div class="swiper-slide" {{ block.shopify_attributes }}>
              {%- if card_collection != blank -%}
                <a
                  href="{{ card_collection.url }}"
                  class="collection-list-swiper__card"
                  style="--card-border-color: {{ block.settings.border_color }}; --card-text-color: {{ block.settings.text_color }};"
                >
                  <h5 class="collection-list-swiper__card-title">
                    {{ collection_title | escape }}
                  </h5>

                  <div class="collection-list-swiper__media">
                    {%- if primary_image != blank -%}
                      {{
                        primary_image
                        | image_url: width: 700
                        | image_tag:
                          class: 'collection-list-swiper__image collection-list-swiper__image--primary',
                          loading: 'lazy',
                          widths: '240, 320, 480, 640, 700',
                          sizes: '(min-width: 990px) 16vw, (min-width: 750px) 22vw, 42vw',
                          alt: card_collection.title | escape
                      }}
                    {%- else -%}
                      <div class="collection-list-swiper__placeholder"></div>
                    {%- endif -%}

                    {%- if hover_image != blank -%}
                      {{
                        hover_image
                        | image_url: width: 700
                        | image_tag:
                          class: 'collection-list-swiper__image collection-list-swiper__image--hover',
                          loading: 'lazy',
                          widths: '240, 320, 480, 640, 700',
                          sizes: '(min-width: 990px) 16vw, (min-width: 750px) 22vw, 42vw',
                          alt: card_collection.title | escape
                      }}
                    {%- endif -%}
                  </div>
                </a>
              {%- else -%}
                <div
                  class="collection-list-swiper__card"
                  style="--card-border-color: {{ block.settings.border_color }}; --card-text-color: {{ block.settings.text_color }};"
                >
                  <h5 class="collection-list-swiper__card-title">Collection</h5>
                  <div class="collection-list-swiper__media">
                    <div class="collection-list-swiper__placeholder"></div>
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';

    function initCollectionListSwiper() {
      const slider = document.querySelector('#CollectionListSwiper-' + sectionId + ' .js-collection-list-swiper');

      if (!slider || typeof Swiper === 'undefined') return;
      if (slider.classList.contains('swiper-initialized')) return;

      new Swiper(slider, {
        slidesPerView: 2.2,
        spaceBetween: 16,
        speed: 700,
        watchOverflow: true,
        navigation: {
          nextEl: '.collection-list-swiper__arrow--next-' + sectionId,
          prevEl: '.collection-list-swiper__arrow--prev-' + sectionId
        },
        breakpoints: {
          750: {
            slidesPerView: 4,
            spaceBetween: 20
          },
          990: {
            slidesPerView: 6,
            spaceBetween: 28
          }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', initCollectionListSwiper);
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === sectionId) {
        initCollectionListSwiper();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Collection list",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Collections",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "Small"
        },
        {
          "value": "h2",
          "label": "Medium"
        },
        {
          "value": "h1",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "collection_name_override",
          "label": "Collection name override"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "Hover image"
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border color",
          "default": "#637AD8"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#637AD8"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        }
      ]
    }
  ]
}
{% endschema %}