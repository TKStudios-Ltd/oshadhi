{%- style -%}

.page-width .description {
  text-align: center;
  padding-top: 50px;
}
.link1 {
  text-align: center;
  padding-top: 10px;
  margin-bottom: 90px;
  width: 100%;
}
.video .video_inner {
  width: 100%;
  height: auto;
  position: relative;
  padding-top: 55.5%;
  margin-top: 5px;
}
.video .video_inner iframe {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}
.video h2, .center {
  text-align: center;
}
.video p {
  text-align: center;
}
@media (min-width: 780px) {
.video {
    width: 33%;
    display: inline-block;
  }
}
{%- endstyle -%}  
<div class="page-width" data-section-id="{{ section.id }}" data-section-type="featured-video-section">
  {% if section.settings.heading != blank %}
    <h2 class="center">{{ section.settings.heading | escape }}</h2>
  {% endif %}
  

  
<div class="video">
    <div class="video_inner">  
  {% if section.settings.video_url_1.id == blank %}
    <iframe src="//www.youtube.com/embed/_9VUPq3SxOc?rel=0&showinfo=0&vq=720" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
  {% else %}
    {% if section.settings.video_url_1.type == "youtube" %}
      <iframe src="//www.youtube.com/embed/{{ section.settings.video_url_1.id }}?vq=720" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
    {% elsif section.settings.video_url_1.type == "vimeo" %}
      <iframe src="//player.vimeo.com/video/{{ section.settings.video_url_1.id }}?byline=0&portrait=0&badge=0" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
    {% endif %}
  {% endif %}
  </div>
  <div class="heading">
    {% if section.settings.heading_1 != blank %}
    <h2 class="text-center">{{ section.settings.heading_1 | escape }}</h2>
    {% endif %}
  </div>
  <div class="text">
    {% if section.settings.text_1 != blank %}
    <p>{{ section.settings.text_1 | escape }}</p>
    {% endif %}
</div>
</div>
  
<div class="video">
  <div class="video_inner">  
  {% if section.settings.video_url_2.id == blank %}
    <iframe src="//www.youtube.com/embed/_9VUPq3SxOc?rel=0&showinfo=0&vq=720" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
  {% else %}
    {% if section.settings.video_url_2.type == "youtube" %}
      <iframe src="//www.youtube.com/embed/{{ section.settings.video_url_2.id }}?vq=720" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
    {% elsif section.settings.video_url_2.type == "vimeo" %}
      <iframe src="//player.vimeo.com/video/{{ section.settings.video_url_2.id }}?byline=0&portrait=0&badge=0" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
    {% endif %}
  {% endif %}
  </div>
  <div class="heading">
    {% if section.settings.heading_2 != blank %}
    <h2 class="text-center">{{ section.settings.heading_2 | escape }}</h2>
  {% endif %}
</div>
  <div class="text">
    {% if section.settings.text_2 != blank %}
    <p>{{ section.settings.text_2 | escape }}</p>
    {% endif %}
</div>
</div>

<div class="video">
    <div class="video_inner">  
  {% if section.settings.video_url_3.id == blank %}
    <iframe src="//www.youtube.com/embed/_9VUPq3SxOc?rel=0&showinfo=0&vq=720" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
  {% else %}
    {% if section.settings.video_url_3.type == "youtube" %}
      <iframe src="//www.youtube.com/embed/{{ section.settings.video_url_3.id }}?vq=720" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
    {% elsif section.settings.video_url_3.type == "vimeo" %}
      <iframe src="//player.vimeo.com/video/{{ section.settings.video_url_3.id }}?byline=0&portrait=0&badge=0" width="1060" height="600" frameborder="0" allowfullscreen></iframe>
    {% endif %}
  {% endif %}
  </div>
  <div class="heading">
    {% if section.settings.heading_3 != blank %}
    <h2 class="text-center">{{ section.settings.heading_3 | escape }}</h2>
  {% endif %}
  </div>
  <div class="text">
    {% if section.settings.text_3 != blank %}
    <p>{{ section.settings.text_3 | escape }}</p>
    {% endif %}
</div>
</div>

  {% if section.settings.description != blank %}
    <div class="description">{{ section.settings.description | escape }}</div>
  {% endif %}
  {% if section.settings.link != blank %}
    <div class="link1"><a href="{{ section.settings.link | escape }}">{{ section.settings.link-text | escape }}</a>
    </div>
  {% endif %}
  
</div>




{% schema %}
  {
    "name": "Video",
    "class": "index-section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Video"
      },
      {
        "type": "html",
        "id": "description",
        "label": "Description",
        "default": "Video Description"
      },
      {
        "type": "text",
        "id": "link-text",
        "label": "Link Text",
        "default": "Link Text"
      },
      {
        "type": "url",
        "id": "link",
        "label": "Link",
        "default": "/collections"
      },
      {
        "type": "video_url",
        "id": "video_url_1",
        "label": "Video link 1",
        "accept": ["youtube", "vimeo"]
      },
      {
        "type": "text",
        "id": "heading_1",
        "label": "Heading 1",
        "default": "Video 1"
      },
      {
        "type": "html",
        "id": "text_1",
        "label": "Text 1",
        "default": "Text 1"
      },
      {
        "type": "video_url",
        "id": "video_url_2",
        "label": "Video link 2",
        "accept": ["youtube", "vimeo"]
      },
      {
        "type": "text",
        "id": "heading_2",
        "label": "Heading 1",
        "default": "Video 2"
      },
       {
        "type": "html",
        "id": "text_2",
        "label": "Text 2",
        "default": "Text 2"
      },
      {
        "type": "video_url",
        "id": "video_url_3",
        "label": "Video link 3",
        "accept": ["youtube", "vimeo"]
      },
      {
        "type": "text",
        "id": "heading_3",
        "label": "Heading 3",
        "default": "Video 3"
      },
       {
        "type": "html",
        "id": "text_3",
        "label": "Text 3",
        "default": "Text 3"
      }
    ],
    "presets": [
      {
        "name": "Video",
        "category": "Video"
      }
    ]
  }
{% endschema %}