{%- style -%}
.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
    }
}

#CtaTiles-{{ section.id }} {
    position: relative;
}
#CtaTiles-{{ section.id }} .cta-tiles__header {
    margin-bottom: 3rem;
}
#CtaTiles-{{ section.id }} .cta-tiles__title {
    margin: 0;
}
#CtaTiles-{{ section.id }} .cta-tiles__grid {
    display: grid;
    gap: 2rem;
}
#CtaTiles-{{ section.id }} .cta-tiles__grid--two-equal {
    grid-template-columns: repeat(2, minmax(0, 1fr));
}

#CtaTiles-{{ section.id }} .cta-tiles__grid--feature-stack {
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    align-items: stretch;
}
#CtaTiles-{{ section.id }} .cta-tiles__stack {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
}

#CtaTiles-{{ section.id }} .cta-tile {
    position: relative;
    display: block;
    min-height: 25rem;
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    background: var(--tile-bg, #f5f5f5);
    color: var(--tile-text, #111111);
}
#CtaTiles-{{ section.id }} .cta-tile--feature {
    min-height: 52rem;
}
#CtaTiles-{{ section.id }} .cta-tile__media,
#CtaTiles-{{ section.id }} .cta-tile__content {
    position: absolute;
    inset: 0;
}
#CtaTiles-{{ section.id }} .cta-tile__media {
    z-index: 1;
    overflow: hidden;
}
#CtaTiles-{{ section.id }} .cta-tile__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
}
#CtaTiles-{{ section.id }} .cta-tile__media--half {
    left: auto;
    width: 48%;
}
#CtaTiles-{{ section.id }} .cta-tile__content {
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 3rem;
}
#CtaTiles-{{ section.id }} .cta-tile__subtitle {
    margin: 0 0 1rem;
    color: inherit;
}
#CtaTiles-{{ section.id }} .cta-tile__heading {
    margin: 0;
    color: inherit;
    line-height: 1;
}
#CtaTiles-{{ section.id }} .cta-tile__heading--full {
    max-width: 58%;
}
#CtaTiles-{{ section.id }} .cta-tile__heading--half {
    max-width: 42%;
}
#CtaTiles-{{ section.id }} .cta-tile__content--center {
    justify-content: center;
}
#CtaTiles-{{ section.id }} .cta-tile__content--bottom {
    justify-content: flex-end;
}
#CtaTiles-{{ section.id }} .cta-tile:hover .cta-tile__media img {
    transform: scale(1.02);
    transition: transform 0.8s ease;
}
#CtaTiles-{{ section.id }} .cta-tile .cta-tile__media img {
    transition: transform 0.8s ease;
}

  @media screen and (max-width: 989px) {
    #CtaTiles-{{ section.id }} .cta-tiles__grid--two-equal,
    #CtaTiles-{{ section.id }} .cta-tiles__grid--feature-stack {
      grid-template-columns: 1fr;
    }

    #CtaTiles-{{ section.id }} .cta-tile--feature {
      min-height: 42rem;
    }

    #CtaTiles-{{ section.id }} .cta-tile {
      min-height: 28rem;
    }

    #CtaTiles-{{ section.id }} .cta-tile__content {
      padding: 2.4rem;
    }

    #CtaTiles-{{ section.id }} .cta-tile__heading,
    #CtaTiles-{{ section.id }} .cta-tile__heading--full,
    #CtaTiles-{{ section.id }} .cta-tile__heading--half {
      max-width: 75%;
    }

    #CtaTiles-{{ section.id }} .cta-tile__media--half {
      width: 44%;
    }
  }

  @media screen and (max-width: 749px) {
    #CtaTiles-{{ section.id }} .cta-tiles__grid,
    #CtaTiles-{{ section.id }} .cta-tiles__stack {
      gap: 1.6rem;
    }

    #CtaTiles-{{ section.id }} .cta-tile {
      min-height: 24rem;
    }

    #CtaTiles-{{ section.id }} .cta-tile--feature {
      min-height: 32rem;
    }

    #CtaTiles-{{ section.id }} .cta-tile__content {
      padding: 2rem;
    }

    #CtaTiles-{{ section.id }} .cta-tile__subtitle {
      margin-bottom: 1.2rem;
    }

    #CtaTiles-{{ section.id }} .cta-tile__heading,
    #CtaTiles-{{ section.id }} .cta-tile__heading--full,
    #CtaTiles-{{ section.id }} .cta-tile__heading--half {
      max-width: 80%;
    }

    #CtaTiles-{{ section.id }} .cta-tile__media--half {
      width: 46%;
    }
  }
{%- endstyle -%}

<div
  id="CtaTiles-{{ section.id }}"
  class="cta-tiles color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
>
  <div class="page-width isolate">
    {%- unless section.settings.title == blank -%}
      <div class="cta-tiles__header">
        <h2 class="cta-tiles__title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endunless -%}

    {%- if section.settings.layout_style == 'two_equal' -%}
      <div class="cta-tiles__grid cta-tiles__grid--two-equal">
        {%- for block in section.blocks -%}
          {%- render 'cta-tile-block', block: block -%}
        {%- endfor -%}
      </div>

    {%- elsif section.settings.layout_style == 'feature_stack' -%}
      <div class="cta-tiles__grid cta-tiles__grid--feature-stack">
        {%- if section.blocks.size > 0 -%}
          {%- assign first_block = section.blocks.first -%}
          {%- render 'cta-tile-block', block: first_block, featured: true -%}
        {%- endif -%}

        <div class="cta-tiles__stack">
          {%- for block in section.blocks offset: 1 -%}
            {%- if forloop.index0 < 2 -%}
              {%- render 'cta-tile-block', block: block -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "CTA tiles",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 6,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "CTA tiles",
      "label": "Section heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Section heading size"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout",
      "default": "two_equal",
      "options": [
        { "value": "two_equal", "label": "2 columns equal" },
        { "value": "feature_stack", "label": "Large first + 2 stacked" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "CTA tile",
      "settings": [
        {
          "type": "text",
          "id": "subtitle",
          "default": "Shop",
          "label": "Subtitle"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "default": "Aroma",
          "label": "CTA title"
        },
        {
          "type": "select",
          "id": "title_size",
          "label": "CTA title size",
          "default": "h1",
          "options": [
            { "value": "h3", "label": "Small" },
            { "value": "h2", "label": "Medium" },
            { "value": "h1", "label": "Large" }
          ]
        },
        {
          "type": "url",
          "id": "link",
          "label": "Tile link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_layout",
          "label": "Image layout",
          "default": "full",
          "options": [
            { "value": "full", "label": "Full cover" },
            { "value": "half", "label": "Half right" }
          ]
        },
        {
          "type": "select",
          "id": "content_vertical_position",
          "label": "Content vertical position",
          "default": "top",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color",
          "default": "#E8E5DE"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#111111"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CTA tiles",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}