<section class="custom-hero-swiper-section color-{{ section.settings.color_scheme }}">
    <div
        class="swiper custom-hero-swiper js-custom-hero-swiper"
        data-section-id="{{ section.id }}"
        data-autoplay="{{ section.settings.autoplay }}"
        data-delay="{{ section.settings.autoplay_delay }}"
        data-speed="{{ section.settings.transition_speed }}"
        data-loop="{{ section.settings.loop_slides }}"
    >
        <div class="swiper-wrapper">
        {% for block in section.blocks %}
            {% liquid
            assign has_video = false
            if block.settings.background_type == 'video' and block.settings.background_video != blank
                assign has_video = true
            endif

            assign overlay_direction = block.settings.overlay_direction
            assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0
            %}

            <div class="swiper-slide" {{ block.shopify_attributes }}>
                <div class="custom-hero-slide">
                    <div class="custom-hero-slide__media">
                        {% if has_video %}
                            <div class="custom-hero-slide__bg-video">
                            {{
                                block.settings.background_video
                                | video_tag:
                                autoplay: true,
                                loop: true,
                                muted: true,
                                controls: false,
                                playsinline: true,
                                image_size: '2000x'
                            }}
                            </div>
                        {% elsif block.settings.background_image != blank %}
                            {{
                            block.settings.background_image
                            | image_url: width: 2400
                            | image_tag:
                                class: 'custom-hero-slide__bg-image',
                                loading: 'lazy',
                                widths: '750, 1100, 1500, 2000, 2400',
                                sizes: '100vw',
                                alt: block.settings.heading | escape
                            }}
                        {% endif %}
                    </div>
                    <div
                        class="custom-hero-slide__overlay"
                        style="background: linear-gradient({{ overlay_direction }}, {{ block.settings.overlay_color_1 | color_modify: 'alpha', overlay_opacity }}, {{ block.settings.overlay_color_2 | color_modify: 'alpha', overlay_opacity }});"
                    >
                    </div>
                    <div class="custom-hero-slide__inner page-width">
                        <div class="custom-hero-slide__content-wrap">
                            <div class="custom-hero-slide__content">
                                {% if block.settings.heading != blank %}
                                    <h1 class="h0">
                                        <em>
                                            {% if block.settings.eyebrow != blank %}
                                                {{ block.settings.eyebrow }}
                                            {% endif %}
                                        </em>
                                        <br>
                                        {{ block.settings.heading }}
                                    </h1>
                                {% endif %}
                                {% if block.settings.text != blank %}
                                    <div class="rte">
                                        {{ block.settings.text }}
                                    </div>
                                {% endif %}
                                {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                                    <div class="custom-hero-slide__buttons">
                                        <a
                                            href="{{ block.settings.button_link }}"
                                            class="button {% if block.settings.button_style_secondary %}button--secondary{% else %}button--primary{% endif %}"
                                        >
                                            {{ block.settings.button_label }}
                                        </a>
                                    </div>
                                {% endif %}
                             </div>
                        </div>
                    </div>
                    <div class="custom-hero-slide__foreground">
                        {% if block.settings.foreground_image != blank %}
                            {{
                                block.settings.foreground_image
                                | image_url: width: 1200
                                | image_tag:
                                    loading: 'lazy',
                                    widths: '400, 600, 800, 1000, 1200',
                                    sizes: '(min-width: 990px) 40vw, 80vw',
                                    alt: block.settings.heading | escape
                            }}
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
        </div>

        <div class="page-width">
            <div class="swiper-pagination custom-hero-pagination--{{ section.id }}"></div>
        </div>

        {% if section.settings.show_arrows %}
            <div class="swiper-button-prev custom-hero-prev--{{ section.id }}"></div>
            <div class="swiper-button-next custom-hero-next--{{ section.id }}"></div>
        {% endif %}
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const sliders = document.querySelectorAll('.js-custom-hero-swiper');

  if (!sliders.length || typeof Swiper === 'undefined') return;

  sliders.forEach((slider) => {
    const sectionId = slider.dataset.sectionId;

    new Swiper(slider, {
        loop: slider.dataset.loop === 'true',
        speed: Number(slider.dataset.speed) || 900,
        slidesPerView: 1,
        spaceBetween: 0,
        autoplay: slider.dataset.autoplay === 'true'
        ? {
            delay: Number(slider.dataset.delay) || 5000,
            disableOnInteraction: false,
            pauseOnMouseEnter: false,
          }
        : false,
      pagination: {
        el: `.custom-hero-pagination--${sectionId}`,
        clickable: true,
      },
      navigation: {
        nextEl: `.custom-hero-next--${sectionId}`,
        prevEl: `.custom-hero-prev--${sectionId}`,
      },
      watchOverflow: true,
    });
  });
});
</script>

<style>
.custom-hero-swiper-section {
    position: relative;
}
.custom-hero-swiper {
    position: relative;
    overflow: hidden;
}
.custom-hero-swiper .swiper-slide {
    position: relative;
    min-height: 75vh;
}
.custom-hero-slide {
    position: relative;
    width: 100%;
    min-height: 600px;
    overflow: hidden;
}
.custom-hero-slide__media {
    position: absolute;
    inset: 0;
    z-index: 1;
}
.custom-hero-slide__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
}
.custom-hero-slide__inner {
    position: relative;
    z-index: 3;
    width: 100%;
    min-height: 600px;
    padding-top: 80px;
    padding-bottom: 60px;
    display: flex;
    align-items: center;
}
.custom-hero-slide__bg-image,
.custom-hero-slide__bg-video,
.custom-hero-slide__bg-video video {
    width: 100%;
    height: 100%;
}
.custom-hero-slide__bg-video video {
    transform: scaleX(-1);
}
.custom-hero-slide__bg-image,
.custom-hero-slide__bg-video video {
    display: block;
    object-fit: cover;
}
.custom-hero-slide__content-wrap {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-height: 600px;
}
@media screen and (min-width: 750px) {
    .custom-hero-slide__content-wrap {
        justify-content: center;
        padding-left: 2rem;
        padding-right: 2rem;
    }
    .custom-hero-slide__foreground img {
        width: min(520px, 100%) !important;
    }
}
@media screen and (min-width: 990px) {
    .custom-hero-slide__content-wrap {
        padding-left: 5rem;
        padding-right: 5rem;
    }
}
.custom-hero-slide__content {
    max-width: 720px;
    align-self: center;
    color: rgb(var(--color-foreground, 255 255 255));
}
.custom-hero-slide__content .h0 {
    line-height: 1; 
    margin: 0 0 1.5rem;
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
}
@media screen and (min-width: 990px) {
    .custom-hero-slide__content p {
        max-width: 440px;
        margin-bottom: 4rem !important;
        font-size: 18px;
        line-height: 1.45;
    }
}
.custom-hero-slide__buttons {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
}
.custom-hero-slide__foreground {
    position: absolute;
    right: -2px;
    bottom: 60px;
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    height: 100%;
    z-index: 2;
}

.custom-hero-slide__foreground img {
    display: block;
    max-width: 100%;
    width: min(280px, 100%);
    height: auto;
}

.custom-hero-swiper-section .swiper-pagination {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 60px;
    z-index: 2;
    text-align: left;
}

.custom-hero-swiper-section .swiper-pagination-bullets {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding-left: 2rem;
    padding-right: 2rem;
}
@media screen and (min-width: 990px) {
    .custom-hero-swiper-section .swiper-pagination-bullets {
        padding-left: 5rem;
        padding-right: 5rem;
    }
}
.custom-hero-swiper-section .swiper-pagination-bullet {
    width: 40px;
    height: 2px;
    border-radius: 0;
    margin: 0 !important;
    background: rgba(255, 255, 255, 0.35);
    opacity: 1;
}
.custom-hero-swiper-section .swiper-pagination-bullet-active {
    background: rgba(255, 255, 255, 1);
}

.custom-hero-swiper-section .swiper-button-prev,
.custom-hero-swiper-section .swiper-button-next {
  width: 48px;
  height: 48px;
  color: #fff;
  top: 50%;
  transform: translateY(-50%);
}

.custom-hero-swiper-section .swiper-button-prev::after,
.custom-hero-swiper-section .swiper-button-next::after {
  font-size: 18px;
}

.custom-hero-swiper-section .page-width {
    position: relative;
}

@media screen and (max-width: 989px) {
    .custom-hero-swiper .swiper-slide,
    .custom-hero-slide,
    .custom-hero-slide__content-wrap {
        min-height: 600px;
    }
    .custom-hero-slide__content p {
        max-width: 300px;
        font-size: 16px;
        line-height: 1.4;
        margin-bottom: 3rem !important;
    }
}
</style>

{% schema %}
{
  "name": "Custom Hero Swiper",
  "tag": "section",
  "class": "section section-custom-hero-swiper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "Autoplay delay",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "default": 5000
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition speed",
      "min": 300,
      "max": 1800,
      "step": 100,
      "unit": "ms",
      "default": 900
    },
    {
      "type": "checkbox",
      "id": "loop_slides",
      "label": "Loop slides",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "select",
          "id": "background_type",
          "label": "Background type",
          "default": "image",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ]
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "video",
          "id": "background_video",
          "label": "Background video"
        },
        {
          "type": "image_picker",
          "id": "foreground_image",
          "label": "Foreground image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Nature,"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Perfectly Distilled"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Carefully selected botanicals crafted with patience and tradition into pure, 100% natural essential oils.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop essential oils"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary",
          "label": "Use secondary button style",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color_1",
          "label": "Overlay color 1",
          "default": "#09120d"
        },
        {
          "type": "color",
          "id": "overlay_color_2",
          "label": "Overlay color 2",
          "default": "#c7d2b6"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 35
        },
        {
          "type": "select",
          "id": "overlay_direction",
          "label": "Overlay direction",
          "default": "90deg",
          "options": [
            { "value": "0deg", "label": "Top to bottom" },
            { "value": "90deg", "label": "Left to right" },
            { "value": "180deg", "label": "Bottom to top" },
            { "value": "270deg", "label": "Right to left" },
            { "value": "135deg", "label": "Diagonal" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}