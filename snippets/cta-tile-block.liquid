{%- liquid
  assign is_featured = false
  if featured == true
    assign is_featured = true
  endif

  assign content_position_class = ''
  case block.settings.content_vertical_position
    when 'center'
      assign content_position_class = 'cta-tile__content--center'
    when 'bottom'
      assign content_position_class = 'cta-tile__content--bottom'
  endcase

  assign title_width_class = 'cta-tile__heading--full'
  if block.settings.image_layout == 'half'
    assign title_width_class = 'cta-tile__heading--half'
  endif

  assign overlay_alpha = block.settings.image_overlay_opacity | divided_by: 100.0
-%}

<a
  {% if block.settings.link != blank %}
    href="{{ block.settings.link }}"
  {% else %}
    role="link" aria-disabled="true"
  {% endif %}
  class="cta-tile{% if is_featured %} cta-tile--feature{% endif %}"
  style="--tile-bg: {{ block.settings.background_color }}; --tile-text: {{ block.settings.text_color }};"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.image != blank -%}
    <div class="cta-tile__media{% if block.settings.image_layout == 'half' %} cta-tile__media--half{% endif %}">
      {{
        block.settings.image
        | image_url: width: 2200
        | image_tag:
          widths: '400, 600, 800, 1100, 1500, 1800, 2200',
          sizes: '(min-width: 990px) 50vw, 100vw',
          alt: block.settings.title | strip_html | escape
      }}
    </div>

    <div
      class="cta-tile__overlay"
      style="background: rgba(0,0,0,{{ overlay_alpha }});"
    ></div>
  {%- endif -%}

  <div class="cta-tile__content {{ content_position_class }}">
    {%- if block.settings.subtitle != blank -%}
      <p class="cta-tile__subtitle h6">{{ block.settings.subtitle }}</p>
    {%- endif -%}

    {%- if block.settings.title != blank -%}
      <div class="cta-tile__heading {{ block.settings.title_size }} {{ title_width_class }}">
        {{ block.settings.title }}
      </div>
    {%- endif -%}
  </div>
</a>